{
  "name": "ghost-blog-static-builder",
  "version": "1.0.0",
  "private": true,
  "description": "A deployment pipeline for converting Ghost CMS into a static site hosted on GitHub Pages.",
  "author": "Harduex",
  "license": "ISC",
  "keywords": [
    "ghost",
    "static-site",
    "github-pages",
    "blog"
  ],
  "scripts": {
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "build": "BUILD_ONLY=true node deploy.js",
    "preview": "npm run build && npx http-server dist -p 8080 -o",
    "deploy": "node deploy.js",
    "export": "node export-md.js"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.3.3",
    "gh-pages": "^6.3.0",
    "mysql2": "^3.22.6",
    "replace-in-file": "^8.4.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
